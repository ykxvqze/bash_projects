            "expected": "644",
            "remediation": "chmod 644 /etc/issue"
        },
        {
            "title": "Ensure a non-informative banner is set",
            "audit": "cat /etc/issue",
            "expected": "Authorized use only. Actions will be logged",
            "remediation": "echo 'Authorized use only. Actions will be logged.' > /etc/issue"
        }
